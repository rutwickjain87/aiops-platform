# K8s Doctor — environment variables
# Copy to .env and fill in real values before running.

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Kubernetes ─────────────────────────────────────────────────────────────────
K8S_CONTEXT=kind-doctor-lab        # kubectl context for the kind cluster

# ── Model routing (Day 7) ──────────────────────────────────────────────────────
OBSERVE_MODEL=claude-haiku-4-5-20251001   # cheap model for kubectl reads
REASON_MODEL=claude-sonnet-4-6            # powerful model for reasoning

# ── Prometheus ─────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090       # local stack or in-cluster

# ── LangSmith tracing ──────────────────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=k8s-doctor

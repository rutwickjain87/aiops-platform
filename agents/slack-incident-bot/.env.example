# Slack credentials — obtained from api.slack.com/apps
SLACK_APP_TOKEN=xapp-1-...        # Socket Mode app-level token (connections:write scope)
SLACK_BOT_TOKEN=xoxb-...          # Bot User OAuth Token (chat:write, channels:read scopes)
SLACK_CHANNEL_ID=C0XXXXXXXXX      # Channel ID where incident cards are posted

# Anthropic — for the LLM incident summariser
ANTHROPIC_API_KEY=sk-ant-...

# Optional: LangSmith tracing
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=aiops-slack-bot

# PR Reviewer — environment variables
# Copy to .env and fill in real values before running.

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...            # Personal access token with repo:read scope

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# Set LANGSMITH_TRACING=true to enable per-review trace trees in LangSmith.
# LangChain auto-traces all ChatAnthropic calls when this is set.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=aiops-pr-reviewer

# ── Prometheus metrics (optional) ──────────────────────────────────────────────
# Set METRICS_ENABLED=true to expose /metrics on METRICS_PORT.
# Default port is 8001 (pr-reviewer) — use 8000 for slack-incident-bot.
METRICS_ENABLED=true
METRICS_PORT=8001

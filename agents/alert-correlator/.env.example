ANTHROPIC_API_KEY=sk-ant-...
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=aiops-alert-correlator
LANGSMITH_TRACING=true

# pgvector connection (matches docker-compose.yml)
PGHOST=localhost
PGPORT=5432
PGDATABASE=alerts
PGUSER=alertcorr
PGPASSWORD=alertcorr

# Correlation config
CORRELATION_WINDOW_MINUTES=30     # look-back window for similar alerts
SIMILARITY_THRESHOLD=0.60         # cosine similarity cutoff — 0.60 suits all-MiniLM-L6-v2
                                  # (Voyage AI voyage-3-lite: use 0.85)
                                  # Run diagnose_similarity.py to calibrate for your model
MIN_CLUSTER_SIZE=2                 # minimum alerts to form an incident
MAX_SIMILAR_ALERTS=20             # cap on pgvector neighbours returned

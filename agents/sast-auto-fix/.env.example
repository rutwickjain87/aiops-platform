# SAST Auto-Fixer — environment variables
# Copy to .env and fill in real values.

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# ── Model routing ──────────────────────────────────────────────────────────────
FIX_MODEL=claude-sonnet-4-6         # model used for the fix node

# ── GitHub PR integration ──────────────────────────────────────────────────────
# Generate at: https://github.com/settings/tokens (repo scope required)
GITHUB_TOKEN=${GITHUB_TOKEN}
PR_REPO=rutwickjain87/sast-lab      # repo to open PRs against

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=${LANGSMITH_API_KEY}
LANGSMITH_PROJECT=sast-auto-fix

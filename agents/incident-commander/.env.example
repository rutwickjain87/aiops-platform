ANTHROPIC_API_KEY=sk-ant-...
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=aiops-incident-commander
LANGSMITH_TRACING=true

# Kubernetes (leave blank if using in-cluster config)
KUBECONFIG=~/.kube/config

# Prometheus (for the Investigator to query metrics)
PROMETHEUS_URL=http://localhost:9090

# Slack (for the Communicator to post incident updates)
SLACK_BOT_TOKEN=xoxb-...
SLACK_INCIDENT_CHANNEL=#incidents

# Safety: require human approval before Mitigator applies any kubectl patch
REQUIRE_HUMAN_APPROVAL=true

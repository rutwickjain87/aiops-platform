# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — never commit real values.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- LangSmith (optional, for tracing) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=aiops-platform

# --- Voyage AI (embeddings) ---
VOYAGE_API_KEY=pa-...

# --- GitHub (for PR Reviewer agent + CI) ---
GITHUB_TOKEN=ghp_...

# --- Slack (for incident bot) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# --- Postgres / pgvector (for alert correlator) ---
DATABASE_URL=postgresql://postgres:pw@localhost:5432/aiops

# --- Ollama (local; no key needed) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b

# --- Cost guards (per-run budget in USD) ---
AGENT_BUDGET_USD=1.00
AGENT_MAX_STEPS=15
